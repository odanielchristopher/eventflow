# Local application environment
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=3000

# Active database URL
# To use SQLite locally, keep DATABASE_URL pointing to sqlite+aiosqlite
# To use PostgreSQL from docker-compose, uncomment the PostgreSQL line instead
DATABASE_URL=sqlite+aiosqlite:///./sqlite_data/eventflow.db
# DATABASE_URL=postgresql+asyncpg://eventflow:eventflow@localhost:5432/eventflow

# Optional explicit URLs for the assignment requirement
SQLITE_DATABASE_URL=sqlite+aiosqlite:///./sqlite_data/eventflow.db
POSTGRES_DATABASE_URL=postgresql+asyncpg://eventflow:eventflow@localhost:5432/eventflow

# Upload base directory for future document endpoints
UPLOAD_DIR=./uploads
